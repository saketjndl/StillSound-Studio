{
    "manifest_version": 3,
    "name": "StillSound Sync",
    "version": "1.0.0",
    "description": "Auto-sync Spotify with YouTube",
    "permissions": [
        "tabs",
        "activeTab",
        "alarms"
    ],
    "host_permissions": [
        "*://*.youtube.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.youtube.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "128": "icons/icon128.png"
        }
    },
    "icons": {
        "128": "icons/icon128.png"
    }
}